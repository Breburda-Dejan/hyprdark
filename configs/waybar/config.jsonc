// hyprdark â€” Waybar
{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 4,
    "reload_style_on_change": true,

    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "__LAPTOP_MODULES__",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "َ°£‡",
        "tooltip": false,
        "on-click": "rofi -show drun"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "َ°®¯",
            "default": "",
            "empty": ""
        },
        "persistent-workspaces": { "*": 5 },
        "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"e-1\" })'",
        "on-scroll-down": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"e+1\" })'"
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 45,
        "separate-outputs": true,
        "rewrite": { "^$": "  hyprdark" }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %d %B %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#cba6f7'><b>{}</b></span>",
                "weekdays": "<span color='#a6adc8'><b>{}</b></span>",
                "today": "<span color='#cba6f7'><b><u>{}</u></b></span>"
            }
        }
    },

    "tray": {
        "icon-size": 15,
        "spacing": 8
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں mute",
        "format-icons": { "headphone": "َ°‹‹", "default": ["َ°•؟", "َ°–€", "َ°•¾"] },
        "on-click": "pavucontrol",
        "on-click-right": "pamixer -t",
        "scroll-step": 5,
        "tooltip-format": "{desc}"
    },

    "network": {
        "format-wifi": "َ°¤¨ {signalStrength}%",
        "format-ethernet": "َ°ˆ€ wired",
        "format-disconnected": "َ°¤­ off",
        "tooltip-format-wifi": "{essid} ({frequency} GHz)\n{ipaddr}\nâ‡£ {bandwidthDownBytes}  â‡، {bandwidthUpBytes}",
        "tooltip-format-ethernet": "{ifname} â€” {ipaddr}\nâ‡£ {bandwidthDownBytes}  â‡، {bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 3,
        "on-click": "sh -c 'command -v nm-connection-editor >/dev/null && nm-connection-editor'"
    },

    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 5,
        "states": { "warning": 70, "critical": 90 },
        "on-click": "alacritty -e btop"
    },

    "memory": {
        "format": "َ°چ› {percentage}%",
        "interval": 5,
        "states": { "warning": 70, "critical": 90 },
        "tooltip-format": "{used:0.1f} / {total:0.1f} GiB",
        "on-click": "alacritty -e btop"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "tooltip": false
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ¼", "َ°پ¾", "َ°‚€", "َ°پ¹"],
        "states": { "warning": 25, "critical": 12 },
        "tooltip-format": "{timeTo}\n{power:0.1f} W",
        "interval": 10
    },

    "custom/power": {
        "format": "âڈ»",
        "tooltip": false,
        "on-click": "wlogout -b 5 -T 400 -B 400"
    }
}
